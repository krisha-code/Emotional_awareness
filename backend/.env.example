FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
DATABASE_URL=postgresql://emotion_user:emotion_pass@localhost:5432/emotion_db
REDIS_URL=redis://localhost:6379/0
FACE_MODEL_PATH=ml/face/models/fer2013_mobilenetv2.h5
TEXT_MODEL_PATH=ml/text/models/distilbert_emotion
SPEECH_MODEL_PATH=ml/speech/models/speech_emotion_cnn_lstm.h5
MAX_CONTENT_LENGTH=16777216
ENCRYPTION_KEY=your-32-byte-encryption-key-here
